# ============================================================
# Google Spreadsheet Monitor — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# -----------------------------------------------------------
# REQUIRED: Google Spreadsheet
# -----------------------------------------------------------
# The ID found in the spreadsheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# -----------------------------------------------------------
# Scheduler
# -----------------------------------------------------------
# How often to check for changes, in milliseconds
# Default: 300000 (5 minutes)
CHECK_INTERVAL_MS=300000

# -----------------------------------------------------------
# OPTIONAL: Telegram Notifications
# -----------------------------------------------------------
# Get a bot token from @BotFather on Telegram
# Get your chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------
# OPTIONAL: Web Dashboard
# -----------------------------------------------------------
# Port for the Express dashboard and REST API
DASHBOARD_PORT=3000

# -----------------------------------------------------------
# OPTIONAL: Notification Channels
# Set to "true" or "false"
# -----------------------------------------------------------
NOTIFY_CONSOLE=true
NOTIFY_DESKTOP=true
NOTIFY_TELEGRAM=false

# -----------------------------------------------------------
# OPTIONAL: History / Snapshots
# -----------------------------------------------------------
# Keep last N diff snapshots in state/history/
MAX_HISTORY_SNAPSHOTS=50

# -----------------------------------------------------------
# OPTIONAL: Logging
# -----------------------------------------------------------
LOG_LEVEL=info
